local function createMobileButton(text, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.92, 0, 0, 52)
	btn.BackgroundColor3 = Color3.fromRGB(15, 35, 75)
	btn.BackgroundTransparency = 0.45
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(200, 220, 255)
	btn.TextSize = 16
	btn.Font = Enum.Font.GothamBold
	btn.Parent = mobileFrame

	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 14)
	local stroke = Instance.new("UIStroke", btn)
	stroke.Color = Color3.fromRGB(100, 200, 255)
	stroke.Thickness = 1.6

	btn.MouseButton1Click:Connect(function()
		callback()
		TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Back), {Size = UDim2.new(0.96, 0, 0, 56)}):Play()
		task.delay(0.1, function()
			TweenService:Create(btn, TweenInfo.new(0.15), {Size = UDim2.new(0.92, 0, 0, 52)}):Play()
		end)
	end)
	return btn
end

-- ==================== FUNCTIONS ====================
local function OffBalanceEveryone()
	local excluded = (Options and Options.ExcludedPlayers and Options.ExcludedPlayers.Value) or {}
	for _, plr in ipairs(Players:GetPlayers()) do
		if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and not excluded[plr] then
			AbilityRemote:FireServer("OffBalance", { target = plr.Character })
		end
	end
end

local function IsRinStyle()
	local playerStats = LocalPlayer:FindFirstChild("PlayerStats")
	if not playerStats or not playerStats:FindFirstChild("Style") or playerStats.Style.Value ~= "Rin" then
		Library:Notify({Title = "you need to use rin", Description = "equip rin", Time = 3})
		return false
	end
	return true
end

local function IsInGame()
	if not LocalPlayer.Team or (LocalPlayer.Team.Name ~= "Home" and LocalPlayer.Team.Name ~= "Away") then
		Library:Notify({Title = "get in the game first", Time = 2})
		return false
	end
	return true
end

local function opCenterOfGravity()
	if not IsInGame() or not IsRinStyle() then return end
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Character then
			AbilityRemote:FireServer("CenterOfGravity", plr.Character)
		end
	end
	Library:Notify({Title = "op center of grav activated", Time = 0.5})
end

local function opOppositeDirection()
	if not IsInGame() or not IsRinStyle() then return end
	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= LocalPlayer and plr.Team and plr.Character then
			AbilityRemote:FireServer("Opposite", { Target = plr.Character })
		end
	end
	Library:Notify({Title = "op opposite direction activated", Time = 0.5})
end


-- Ball Noclip
local BallNoclippingConnection
local BallClip = true
local function UpdateBallNoclip()
	local ball = workspace:FindFirstChild("Football")
	if not ball then return end
	local state = not BallClip
	for _, p in pairs(ball:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = state end end
	if ball:IsA("BasePart") then ball.CanCollide = state end
end

Toggles.BallNoclip:OnChanged(function()
	BallClip = not Toggles.BallNoclip.Value
	if BallNoclippingConnection then BallNoclippingConnection:Disconnect() end
	if not BallClip then BallNoclippingConnection = RunService.Stepped:Connect(UpdateBallNoclip) else UpdateBallNoclip() end
end)


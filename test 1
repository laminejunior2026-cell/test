-- ==================== BALL CONTROL ====================
local enabled = false
local connection, bodyVelocity, bodyGyro
local SPEED = 200

local function enableMove()
	repeat task.wait() until workspace:FindFirstChild("Football") or not enabled
	if not enabled then return end
	local ball = workspace:FindFirstChild("Football")
	if not ball then return end

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
	bodyVelocity.Parent = ball

	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.MaxTorque = Vector3.new(1e9, 1e9, 1e9)
	bodyGyro.P = 10000
	bodyGyro.Parent = ball

	camera.CameraType = Enum.CameraType.Custom
	camera.CameraSubject = ball

	connection = RunService.RenderStepped:Connect(function()
		if not ball or not ball.Parent then return end
		local lookDir = camera.CFrame.LookVector
		bodyVelocity.Velocity = lookDir * SPEED
		bodyGyro.CFrame = CFrame.lookAt(ball.Position, ball.Position + lookDir)
	end)
end

local function disableMove()
	if connection then connection:Disconnect() connection = nil end
	if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
	if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
	camera.CameraType = Enum.CameraType.Custom
	camera.CameraSubject = humanoid
end

MainGroup:AddToggle("BallMoveToggle", { Text = "curve gyro pro 🥀", Default = false })
MainGroup:AddToggle("BallNoclip", { Text = "noclip ball", Default = false }):AddKeyPicker("BallNoclipKeybind", { Default = "None", Mode = "Toggle", Text = "toggle noclip ball", SyncToggleState = true })

local BallNoclippingConnection = nil
local BallClip = true 

local function UpdateBallNoclip()
	local ball = workspace:FindFirstChild("Football")
	if not ball then return end
	if not BallClip then
		for _, child in pairs(ball:GetDescendants()) do
			if child:IsA("BasePart") then child.CanCollide = false end
		end
		if ball:IsA("BasePart") then ball.CanCollide = false end
	else
		for _, child in pairs(ball:GetDescendants()) do
			if child:IsA("BasePart") then child.CanCollide = true end
		end
		if ball:IsA("BasePart") then ball.CanCollide = true end
	end
end

Toggles.BallNoclip:OnChanged(function()
	BallClip = not Toggles.BallNoclip.Value
	if BallNoclippingConnection then BallNoclippingConnection:Disconnect() BallNoclippingConnection = nil end
	if not BallClip then
		BallNoclippingConnection = RunService.Stepped:Connect(UpdateBallNoclip)
	else
		UpdateBallNoclip()
	end
end)


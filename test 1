local BallNoclippingConnection = nil
local BallClip = true 

local function UpdateBallNoclip()
    local ball = workspace:FindFirstChild("Football")
    if not ball then return end
    for _, child in pairs(ball:GetDescendants()) do
        if child:IsA("BasePart") then
            child.CanCollide = BallClip
        end
    end
    if ball:IsA("BasePart") then
        ball.CanCollide = BallClip
    end
end

Toggles.BallNoclip:OnChanged(function()
    BallClip = not Toggles.BallNoclip.Value
    if BallNoclippingConnection then
        BallNoclippingConnection:Disconnect()
        BallNoclippingConnection = nil
    end
    if not BallClip then
        BallNoclippingConnection = RunService.Stepped:Connect(UpdateBallNoclip)
    else
        UpdateBallNoclip()
    end
end)


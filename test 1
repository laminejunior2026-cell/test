	end
end)

local function createMobileButton(text, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.92, 0, 0, 52)
	btn.BackgroundColor3 = Color3.fromRGB(15, 35, 75)
	btn.BackgroundTransparency = 0.45
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(200, 220, 255)
	btn.TextSize = 16
	btn.Font = Enum.Font.GothamBold
	btn.Parent = mobileFrame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 14)
	corner.Parent = btn

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(100, 200, 255)
	stroke.Thickness = 1.6
	stroke.Transparency = 0.4
	stroke.Parent = btn

	btn.MouseButton1Click:Connect(function()
		callback()
		-- Nice pop animation
		TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0.96, 0, 0, 56)}):Play()
		task.delay(0.1, function()
			TweenService:Create(btn, TweenInfo.new(0.15), {Size = UDim2.new(0.92, 0, 0, 52)}):Play()
		end)
	end)
	return btn
end


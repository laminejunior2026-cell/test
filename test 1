local function createMobileButton(text, callback)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.92, 0, 0, 52)
	btn.BackgroundColor3 = Color3.fromRGB(15, 35, 75)
	btn.BackgroundTransparency = 0.45
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(200, 220, 255)
	btn.TextSize = 16
	btn.Font = Enum.Font.GothamBold
	btn.Parent = mobileFrame

	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 14)
	Instance.new("UIStroke", btn).Color = Color3.fromRGB(100, 200, 255)

	btn.MouseButton1Click:Connect(function()
		callback()
		TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Back), {Size = UDim2.new(0.96,0,0,56)}):Play()
		task.delay(0.1, function() TweenService:Create(btn, TweenInfo.new(0.15), {Size = UDim2.new(0.92,0,0,52)}):Play() end)
	end)
	return btn
end


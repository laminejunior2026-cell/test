-- Ball Noclip logic (original)
local BallNoclippingConnection = nil
local BallClip = true 

local function UpdateBallNoclip()
	local ball = workspace:FindFirstChild("Football")
	if not ball then return end
	if not BallClip then
		for _, child in pairs(ball:GetDescendants()) do
			if child:IsA("BasePart") then child.CanCollide = false end
		end
		if ball:IsA("BasePart") then ball.CanCollide = false end
	else
		for _, child in pairs(ball:GetDescendants()) do
			if child:IsA("BasePart") then child.CanCollide = true end
		end
		if ball:IsA("BasePart") then ball.CanCollide = true end
	end
end

Toggles.BallNoclip:OnChanged(function()
	BallClip = not Toggles.BallNoclip.Value
	if BallNoclippingConnection then BallNoclippingConnection:Disconnect() BallNoclippingConnection = nil end
	if not BallClip then
		BallNoclippingConnection = RunService.Stepped:Connect(UpdateBallNoclip)
	else
		UpdateBallNoclip()
	end
end)

